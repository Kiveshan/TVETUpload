    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
