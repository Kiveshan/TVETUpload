DATABASE_URL="postgresql://user:password@localhost:5432/tvetupload"
PORT=3000
# Comma-separated. Include the Vite dev port (5173).
FRONTEND_ORIGINS="http://localhost:5173"
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-in-production"
# AWS S3 — region matches infra/variables.tf default
AWS_REGION="af-south-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
S3_BUCKET_NAME="tvet-uploads"
